# For LOCAL runs only. In GitHub Actions these come from repo Secrets instead.
# Copy to .env and fill in. Do NOT commit real values (.env is gitignored).

ETIME_USERNAME=your-etime-username
ETIME_PASSWORD=your-etime-password
CORPORATE_ID=landeed

# Slack incoming webhook (rotate the old exposed one and paste the new URL here)
SLACK_WEBHOOK=https://hooks.slack.com/services/XXX/YYY/ZZZ

# Where the bookmark/state is stored.
STATE_PATH=state.json

# Always-on mode only (ignored when RUN_ONCE=1).
POLL_SECONDS=60
MAX_POST_PER_RUN=25
